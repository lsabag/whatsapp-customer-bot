# העתק קובץ זה ל-.env ומלא את המפתח שלך
# Copy this file to .env and fill in your key

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# מודל Claude שבו הבוט משתמש.
# ברירת מחדל: claude-opus-4-8 (החכם ביותר).
# לתגובות מהירות/זולות יותר אפשר לשנות ל: claude-sonnet-4-6 או claude-haiku-4-5
MODEL=claude-opus-4-8
